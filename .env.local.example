# =============================================================================
# Quanta Foundry — Local Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the real values.
# NEVER commit `.env.local` to git — it is already in .gitignore.
#
# These same variables must also be set in your Vercel project:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Airtable
# -----------------------------------------------------------------------------
# Your Airtable Personal Access Token.
# Create one at: https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write
# Scope it to the "Quanta Foundry" base only for security.
AIRTABLE_API_KEY=your_airtable_personal_access_token_here

# The ID of your Airtable base (starts with "app").
# Find it in your base URL: https://airtable.com/app09wCu2hJGlwKwJ/...
AIRTABLE_BASE_ID=app09wCu2hJGlwKwJ

# Optional: Override default table names if you named them differently.
# If not set, the code uses the defaults shown below as fallback values.
# AIRTABLE_TABLE_NAME=Workspace Q Registrations
# AIRTABLE_RC_TABLE_NAME=Reading Club Registrations
# AIRTABLE_CORPORATE_TABLE_NAME=Corporate Inquiries
